# Database (local dev)
DATABASE_URL=postgresql+psycopg://subvenciones:subvenciones@localhost:5432/subvenciones

# App
BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# BDNS
BDNS_BASE_URL=https://www.infosubvenciones.es/bdnstrans/api
BDNS_PAGE_SIZE=100
BDNS_SYNC_HOUR=3
BDNS_SYNC_MINUTE=0

# Matching
MATCHING_CANDIDATE_LIMIT=30
# Gemini LLM (optional — leaves scoring deterministic if empty)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Brevo email (deja en blanco para log-only mode)
BREVO_API_KEY=
ALERT_FROM_EMAIL=alertas@flexigobe.com
ALERT_ADMIN_EMAIL=

# Admin panel (HTTP Basic). Deja vacío en dev y autoreusará credenciales aleatorias
# que aparecerán en el log al arrancar. En producción establece estos valores y NO los
# subas a git.
ADMIN_USER=
ADMIN_PASS=

# Rate limiting (POST /search). Por usuario (IP+UA hash) por hora.
RATE_LIMIT_PER_HOUR=60
